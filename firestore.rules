// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - email: string (required, email)
//   - name: string (required)
//   - createdAt: timestamp (required)
//
// Collection: children
// Document ID: {childId}
// Fields:
//   - userId: string (required)
//   - name: string (required)
//   - birthDate: string (required, YYYY-MM-DD)
//   - gender: string (optional)
//
// Collection: photos
// Document ID: {photoId}
// Fields:
//   - childId: string (required)
//   - url: string (required, uri)
//   - dateTaken: timestamp (required)
//   - estimatedAge: number (optional)
//   - category: string (optional)
//
// Collection: videos
// Document ID: {videoId}
// Fields:
//   - childId: string (required)
//   - videoUrl: string (required, uri)
//   - templateUsed: string (optional)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Always allow for Personal Edition (No-auth)
    function isOpen() {
      return true;
    }

    // Domain Validators (Simplified for MVP)
    function isValidChild(data) {
      return data.keys().hasAll(['name', 'birthDate']);
    }

    function isValidPhoto(data) {
      return data.keys().hasAll(['childIds', 'imageUrl', 'takenAt']);
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['childId', 'title', 'scenes']);
    }

    // Rules
    match /users/{userId} {
      allow read, write: if isOpen();
    }

    match /children/{childId} {
      allow read, write: if isOpen();
    }

    match /photos/{photoId} {
      allow read, write: if isOpen();
    }

    match /videoProjects/{projectId} {
      allow read, write: if isOpen();
    }
  }
}
